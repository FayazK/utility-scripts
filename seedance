#!/usr/bin/env python3
"""Generate videos via ByteDance's Seedance 2.0 models on Kie AI."""

import argparse
import os
import sys
from datetime import datetime
from pathlib import Path

sys.path.insert(0, os.path.dirname(os.path.realpath(__file__)))

from kie_api import (
    KieError,
    create_task,
    download_result_urls,
    get_api_key,
    poll_task,
    resolve_to_url,
    result_urls,
)

MODELS = {
    "pro": "bytedance/seedance-2",
    "fast": "bytedance/seedance-2-fast",
}

ASPECT_RATIOS = ["16:9", "4:3", "1:1", "3:4", "9:16", "21:9", "adaptive"]
RESOLUTIONS = ["480p", "720p", "1080p"]


def parse_args():
    p = argparse.ArgumentParser(
        description=(
            "Generate videos with ByteDance Seedance 2.0 (Pro or Fast) via "
            "the Kie AI API. Supports text-to-video, image-to-video, first+"
            "last frame interpolation, and reference images/videos/audios "
            "for character, style, motion, and lip-sync control. Local "
            "images/videos/audios are uploaded to Kie's temporary file "
            "store; http(s):// URLs are passed through as-is."
        ),
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )
    p.add_argument("prompt", help="Text prompt for video generation (3-20000 chars).")
    p.add_argument(
        "-o", "--output-dir", required=True,
        help="Directory to write generated MP4 into. Created if missing.",
    )
    p.add_argument(
        "-m", "--model", choices=list(MODELS), default="fast",
        help="Model variant: 'pro' = seedance-2 (supports 1080p), 'fast' = seedance-2-fast.",
    )
    p.add_argument(
        "-d", "--duration", type=int, default=5,
        help="Video duration in seconds (4-15).",
    )
    p.add_argument(
        "-s", "--resolution", choices=RESOLUTIONS, default="720p",
        help="Video resolution. 1080p requires --model=pro.",
    )
    p.add_argument(
        "-a", "--aspect-ratio", choices=ASPECT_RATIOS, default="16:9",
        help="Video aspect ratio. 'adaptive' lets the model choose.",
    )
    p.add_argument(
        "--no-audio", action="store_true",
        help="Disable synchronized audio generation (audio is on by default).",
    )
    p.add_argument(
        "-i", "--image", default=None, metavar="PATH_OR_URL",
        help="First-frame image for image-to-video. Local path or URL.",
    )
    p.add_argument(
        "-l", "--last-frame", default=None, metavar="PATH_OR_URL",
        help="Last-frame image for interpolation. Requires --image.",
    )
    p.add_argument(
        "--ref-image", action="append", default=[], metavar="PATH_OR_URL",
        help="Reference image (up to 9). Repeat flag.",
    )
    p.add_argument(
        "--ref-video", action="append", default=[], metavar="PATH_OR_URL",
        help="Reference video (up to 3, each 2-15s, total ≤15s). Repeat flag.",
    )
    p.add_argument(
        "--ref-audio", action="append", default=[], metavar="PATH_OR_URL",
        help="Reference audio (up to 3, each 2-15s, total ≤15s). Repeat flag.",
    )
    p.add_argument(
        "-n", "--name", default=None,
        help="Output filename stem (no extension). Defaults to a timestamp.",
    )
    p.add_argument(
        "--poll-interval", type=int, default=5,
        help="Seconds between status polls while waiting for generation.",
    )
    p.add_argument(
        "--timeout", type=int, default=900,
        help="Max seconds to wait for generation to complete.",
    )
    return p.parse_args()


def main():
    args = parse_args()

    # Validation mirroring the Kie Seedance-2 schema (4-15s duration, 1080p
    # pro-only, first/last-frame exclusive with reference_image_urls, etc.).
    if args.last_frame and not args.image:
        sys.exit("error: --last-frame requires --image.")
    if (args.image or args.last_frame) and args.ref_image:
        sys.exit("error: --image/--last-frame cannot be combined with --ref-image.")
    if not (4 <= args.duration <= 15):
        sys.exit("error: --duration must be between 4 and 15.")
    if len(args.ref_image) > 9:
        sys.exit("error: at most 9 --ref-image values allowed.")
    if len(args.ref_video) > 3:
        sys.exit("error: at most 3 --ref-video values allowed.")
    if len(args.ref_audio) > 3:
        sys.exit("error: at most 3 --ref-audio values allowed.")
    if args.resolution == "1080p" and args.model != "pro":
        sys.exit("error: 1080p resolution requires --model=pro.")

    try:
        api_key = get_api_key()

        input_body = {
            "prompt": args.prompt,
            "duration": args.duration,
            "resolution": args.resolution,
            "aspect_ratio": args.aspect_ratio,
            "generate_audio": not args.no_audio,
        }
        if args.image:
            input_body["first_frame_url"] = resolve_to_url(
                args.image, api_key, label="--image"
            )
        if args.last_frame:
            input_body["last_frame_url"] = resolve_to_url(
                args.last_frame, api_key, label="--last-frame"
            )
        if args.ref_image:
            input_body["reference_image_urls"] = [
                resolve_to_url(r, api_key, label="--ref-image") for r in args.ref_image
            ]
        if args.ref_video:
            input_body["reference_video_urls"] = [
                resolve_to_url(r, api_key, label="--ref-video") for r in args.ref_video
            ]
        if args.ref_audio:
            input_body["reference_audio_urls"] = [
                resolve_to_url(r, api_key, label="--ref-audio") for r in args.ref_audio
            ]

        task_id = create_task(MODELS[args.model], input_body, api_key)
        data = poll_task(
            task_id, api_key,
            poll_interval=args.poll_interval,
            timeout=args.timeout,
            on_wait=lambda d: print(
                f"Waiting for video generation... state={d.get('state')} "
                f"(task {task_id}, polling every {args.poll_interval}s)"
            ),
        )
        urls = result_urls(data)
    except KieError as e:
        sys.exit(f"error: {e}")

    if not urls:
        sys.exit(f"error: task {task_id} succeeded but has no resultUrls.")

    out_dir = Path(args.output_dir).expanduser()
    stem = args.name or datetime.now().strftime("seedance-%Y%m%d-%H%M%S")
    saved = download_result_urls(urls, out_dir, stem, default_ext="mp4")

    for p in saved:
        print(p)


if __name__ == "__main__":
    main()
